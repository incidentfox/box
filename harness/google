#!/usr/bin/env bash
# `google` command wrapper. The real CLI is google.mjs (ESM). Box's repo is
# "type": "module", and Node can't run an *extensionless* file in that context
# (ERR_UNKNOWN_FILE_EXTENSION) — but a .mjs is always loaded as ESM. This wrapper
# resolves its own real location (following the ~/.local/bin and ~/.claude/box-harness
# symlinks) so google.mjs is found beside it. Portable: no `readlink -f` (BSD/macOS lacks it).
src="$0"
while [ -L "$src" ]; do
  d="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
  src="$(readlink "$src")"
  case "$src" in /*) ;; *) src="$d/$src" ;; esac
done
d="$(cd -P "$(dirname "$src")" >/dev/null 2>&1 && pwd)"
exec node "$d/google.mjs" "$@"
