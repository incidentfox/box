# ─────────────────────────────────────────────────────────────────────────────
#  Box configuration — copy to `.env` and fill in.  Everything except the auth
#  token is OPTIONAL: with nothing else set, Box runs as a clean chat app that
#  drives Claude Code (and Codex, if installed) on this machine.
#
#  `./install.sh` creates this file for you and generates a token automatically.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — the password you type to log into the web app. Keep it long & secret.
# If you leave this unset, the server generates a random one and writes it here on boot.
CC_AUTH_TOKEN=

# Port the Node server listens on (the tunnel / reverse-proxy points at this).
PORT=7321

# Default working directory new chats open in (and where project /skills are scanned).
# RECOMMENDED: point this at your main code directory. Defaults to $HOME, which works
# but is a poor place to work — claude shows a "launched in your home directory" notice
# and takes longer to become ready. ./install.sh asks for this interactively.
# CC_WORKSPACE=/home/youruser/code

# Your name — used in the per-session "morning brief" status doc the app maintains.
OWNER_NAME=you

# ── Voice (optional) ─────────────────────────────────────────────────────────
# Speech-to-text for the mic button. Leave both unset to disable voice.
#   ElevenLabs Scribe — zero-friction, multilingual.  https://elevenlabs.io
# ELEVENLABS_API_KEY=
#   Deepgram nova-3 — higher-quality batch transcription.  https://deepgram.com
# DEEPGRAM_API_KEY=

# ── Codex (optional) ─────────────────────────────────────────────────────────
# Codex chats appear automatically if the `codex` CLI is installed & logged in.
# The in-app Settings sheet can change the default permissions mode. This env var is
# only the install-time fallback: off = Box YOLO, or use workspace-write/read-only.
# CODEX_SANDBOX=off

# ── Board + "needs you" inbox ────────────────────────────────────────────────
# These power the in-app Board tab and the "needs you" decision inbox. You DON'T
# need a Linear account: with no LINEAR_API_KEY, the box runs a built-in, local
# clone of Linear backed by a SQLite file (~/.cc-mobile/linear-lite.db). It works
# out of the box — and if you connect a real Linear later, push everything up with:
#   node bin/linear-lite.mjs import --key <lin_api_…> --team-key <KEY>
#
#   LINEAR_TEAM_KEY = the short key shown on issues, e.g. TASK in TASK-123. In LOCAL
#                     mode it just names your local tickets (default: TASK).
# LINEAR_TEAM_KEY=
#   NEEDS_LABEL     = the label that flags an issue as needing YOUR personal decision.
NEEDS_LABEL=needs-me
#   LINEAR_LOCAL=off disables the Board entirely instead of using the local clone.
# LINEAR_LOCAL=off
#
# To drive a REAL Linear workspace instead of the local clone, set an API key
# (Linear → Settings → Security & access → Personal API keys) + the team's UUID:
# LINEAR_API_KEY=
# LINEAR_TEAM_ID=     # the team's GraphQL UUID (NOT the short key); see concierge/30-linear.md

# ── Optional integrations used by some advanced features ─────────────────────
# GitHub token (so the Board can show / merge the PR linked to an issue).
# GITHUB_TOKEN=
# OpenAI key — powers the cheap per-session "morning brief" summariser. Without it,
# the brief feature is simply skipped (chat is unaffected).
# OPENAI_API_KEY=
# OPENAI_ENDPOINT=https://api.openai.com/v1
# BOX_ATTENTION_MODEL=gpt-4o-mini

# Optional: source secrets from an external env file instead of duplicating them here.
# EXTRA_ENV_FILE=/path/to/secrets.env

# Optional: a notes/"brain" directory (markdown). If it contains a meetings/ subdir
# it powers the Pipelines tab; otherwise harmless.
# BRAIN_DIR=/home/youruser/brain

# ── Voice assistant (realtime, hands-free) ───────────────────────────────────
# A "Voice" mode in the app: talk to your box like a phone call. Browser connects
# to OpenAI's Realtime API over WebRTC; every tool call (sessions, board, research,
# notes, email…) executes on this server. Requires OPENAI_API_KEY above.
# VOICE_ASSISTANT_MODEL=gpt-realtime-2      # or gpt-realtime-1.5 / gpt-realtime-mini (cheaper)
# VOICE_ASSISTANT_VOICE=marin               # alloy|ash|ballad|coral|echo|sage|shimmer|verse|marin|cedar
# VOICE_ASSISTANT_VAD=semantic              # semantic (natural pauses) | server (fixed silence cutoff)
# VOICE_ASSISTANT_RESPONSE_STYLE=brief      # brief (default) | normal | expanded
# VOICE_ASSISTANT_INTERRUPT_RESPONSE=0      # set 1 to allow barge-in to interrupt speech
# Optional: web search + deep research tools use Parallel (parallel.ai):
# PARALLEL_API_KEY=
# VOICE_ASSISTANT_EAGERNESS=low             # semantic VAD: low (patient) | medium | high (snappy) | auto
# VOICE_ASSISTANT_REASONING=low             # gpt-realtime-2 reasoning effort (none to disable)
# VOICE_THINKER_CLAUDE_MODEL=fable          # think_hard runs Claude via the local CLI (Max plan)
# VOICE_THINKER_FALLBACK_MODEL=gpt-5.5      # OpenAI fallback when the Claude CLI/credits are unavailable
# VOICE_FILE_ACCESS_ROOTS=                  # optional path-list; defaults to ~/development, ~/Downloads, uploads, /tmp
# VOICE_FILE_ACCESS_MAX_BYTES=26214400      # max file size for mediated spreadsheet ingest

# ── Slack context (optional) ─────────────────────────────────────────────────
# Read-only Slack context for agents + the voice assistant. Use a user token (xoxp)
# for search.messages; a bot token (xoxb) can read recent messages only where the
# app/bot has channel/DM history scopes and access. Extracted web xoxc tokens also
# require the matching browser d cookie, and expire with that browser session.
# SLACK_USER_TOKEN=
# SLACK_COOKIE=
# SLACK_COOKIE_D=
# SLACK_BOT_TOKEN=
# SLACK_TOKEN=
# SLACK_CHANNELS=#ops,C1234567890           # optional comma-separated names/ids
# SLACK_RECENT_LOOKBACK_HOURS=24
# SLACK_CONTEXT_MAX_MESSAGES=12
# SLACK_CONTEXT_MAX_CHARS=5000
